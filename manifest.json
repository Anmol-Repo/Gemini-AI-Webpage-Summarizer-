{
    "manifest_version": 3,
    "name": "AI-Powered Web Page Summarizer",
    "version": "1.0",

    "permissions":["scripting","activeTab","storage"],

    "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
    
    "action":{
        "default_popup":"popup.html",
        "default_icon":"icon.png" ,
        "16": "icon.png" ,
        "32": "icon.png",
        "48": "icon.png",
        "128": "icon.png"

    },

    "content_scripts":[
        {
            "matches":["<all_urls>"],
            "js":["content.js"]
        }
    ],

    "background":{
        "service_worker":"background.js"
    },
    
    "options_page": "options.html",

    "host_permissions": ["<all_urls>"]

}
